*.temp
*.log
*.bak
*.swp

# R cache
.Rcache/
.cache/

####################################
# Data (依你研究需求調整)
####################################

# 大型原始資料（通常不進 git）
data/raw/
data/tmp/
data/cache/

# 若你「完全不想 commit data」，用這行
# data/

# 若你「只想 commit processed data」，請保留：
# !data/processed/

